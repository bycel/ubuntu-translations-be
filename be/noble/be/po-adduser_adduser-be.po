#: adduser:229
msgid "Only root may add a user or group to the system."
msgstr "Толькі адміністратар можа дадаваць карыстальніка або групу ў сістэму."

#: adduser:275 deluser:208
msgid "Only one or two names allowed."
msgstr "Дазволена ўказваць толькі адно або два імі."

#: adduser:282
msgid "Specify only one name in this mode."
msgstr "У гэтым рэжыме можна ўказаць толькі адно імя."

#: adduser:286
msgid "addgroup with two arguments is an unspecified operation."
msgstr "addgroup з двума аргументамі з'яўляецца непазначанай аперацыяй."

#: adduser:318
msgid "The --group, --ingroup, and --gid options are mutually exclusive."
msgstr "Параметры --group, --ingroup, і --gid узаемна выключальныя."

#: adduser:403
msgid "The home dir must be an absolute path."
msgstr "Хатні каталог павінен быць абсалютным шляхам."

#: adduser:651 adduser:897
#, perl-format
msgid "The home dir %s you specified already exists.\n"
msgstr "Указаная вамі хатняя папка %s ужо існуе.\n"

#: adduser:654 adduser:900
#, perl-format
msgid "The home dir %s you specified can't be accessed: %s\n"
msgstr "Да ўказанага вамі хатняга каталога %s адсутнічае доступ: %s\n"

#: ../adduser:347
#, perl-format
msgid "The group `%s' already exists as a system group. Exiting."
msgstr "Група «%s» ужо існуе як сістэмная група. Адбываецца выхад."

#: adduser:454
#, perl-format
msgid "The group `%s' already exists and is not a system group. Exiting."
msgstr "Група «%s» ужо існуе і не з'яўляецца сістэмнай групай. Адбываецца выхад."

#: adduser:445
#, perl-format
msgid "The group `%s' already exists, but has a different GID. Exiting."
msgstr "Група «%s» ужо існуе, але мае іншы GID. Адбываецца выхад."

#: adduser:459 adduser:499
#, perl-format
msgid "The GID `%s' is already in use."
msgstr "GID «%s» ужо выкарыстоўваецца."

#: adduser:470
#, perl-format
msgid "No GID is available in the range %d-%d (FIRST_SYS_GID - LAST_SYS_GID)."
msgstr "Няма даступных GID у дыяпазоне %d-%d (FIRST_SYS_GID - LAST_SYS_GID)."

#: adduser:472 adduser:518
#, perl-format
msgid "The group `%s' was not created."
msgstr "Група «%s» не створана."

#: adduser:478 adduser:523
#, perl-format
msgid "Adding group `%s' (GID %d) ..."
msgstr "Дадаецца группа «%s» (GID %d)..."

#: adduser:495 adduser:1232
#, perl-format
msgid "The group `%s' already exists."
msgstr "Група «%s» ужо існуе."

#: adduser:516
#, perl-format
msgid "No GID is available in the range %d-%d (FIRST_GID - LAST_GID)."
msgstr "Няма даступных GID у дыяпазоне %d-%d (FIRST_GID - LAST_GID)."

#: adduser:540 deluser:296
#, perl-format
msgid "The user `%s' does not exist."
msgstr "Карыстальнік «%s» не існуе."

#: adduser:544 adduser:1009 adduser:1242 deluser:456 deluser:459
#, perl-format
msgid "The group `%s' does not exist."
msgstr "Група «%s» не існуе."

#: adduser:549 adduser:1013
#, perl-format
msgid "The user `%s' is already a member of `%s'."
msgstr "Карыстальнік «%s» ужо з'яўляецца ўдзельнікам «%s»."

#: adduser:553 adduser:1019
#, perl-format
msgid "Adding user `%s' to group `%s' ..."
msgstr "Дадаецца карыстальнік «%s» у групу «%s»..."

#: adduser:579
#, perl-format
msgid "The system user `%s' already exists. Exiting.\n"
msgstr "Сістэмны карыстальнік «%s» ужо існуе. Адбываецца выхад.\n"

#: adduser:571
#, perl-format
msgid "The user `%s' already exists, but is not a system user. Exiting."
msgstr "Карыстальнік «%s» ужо існуе, але не з'яўляецца карыстальнікам сістэмы. Адбываецца выхад."

#: adduser:575
#, perl-format
msgid "The user `%s' already exists with a different UID. Exiting."
msgstr "Карыстальнік «%s» ужо існуе з іншым UID. Адбываецца выхад."

#: adduser:593
#, perl-format
msgid "No UID/GID pair is available in the range %d-%d (FIRST_SYS_UID - LAST_SYS_UID)."
msgstr "Няма даступнай пары UID/GID у дыяпазоне %d-%d (FIRST_SYS_UID - LAST_SYS_UID)."

#: adduser:596 adduser:612 adduser:712 adduser:826 adduser:832
#, perl-format
msgid "The user `%s' was not created."
msgstr "Карыстальнік «%s» не быў створаны."

#: adduser:609
#, perl-format
msgid "No UID is available in the range %d-%d (FIRST_SYS_UID - LAST_SYS_UID)."
msgstr "Няма даступнага UID у дыяпазоне %d-%d (FIRST_SYS_UID - LAST_SYS_UID)."

#: ../adduser:517 ../adduser:529
msgid "Internal error"
msgstr "Унутраная памылка"

#: adduser:636
#, perl-format
msgid "Adding system user `%s' (UID %d) ..."
msgstr "Дадаецца сістэмны карыстальнік «%s» (UID %d) ..."

#: adduser:640
#, perl-format
msgid "Adding new group `%s' (GID %d) ..."
msgstr "Дадаецца новая група «%s» (GID %d)..."

#: adduser:658
#, perl-format
msgid "Adding new user `%s' (UID %d) with group `%s' ..."
msgstr "Дадаецца новы карыстальнік «%s» (UID %d) з групай «%s»..."

#: adduser:711
msgid "USERS_GID and USERS_GROUP both given in configuration. This is an error."
msgstr "У канфігурацыі прыведзены абодва ідэнтыфікатары USERS_GID і USERS_GROUP. Гэта з'яўляецца памылкай."

#: adduser:802
#, perl-format
msgid "Adding user `%s' ..."
msgstr "Дадаецца карыстальнік «%s»..."

#: adduser:825
#, perl-format
msgid "No UID/GID pair is available in the range %d-%d (FIRST_UID - LAST_UID)."
msgstr "Няма даступнай пары UID/GID у дыяпазоне %d-%d (FIRST_UID - LAST_UID)."

#: adduser:831
msgid "USERGROUPS=no, USER_GID=-1 and USERS_GROUP empty. A user needs a primary group!"
msgstr "USERGROUPS=no, USER_GID=-1 і USERS_GROUP пусты. Карыстальніку неабходна першасная група!"

#: adduser:871
msgid "Internal error interpreting parameter combination"
msgstr "Унутраная памылка інтэрпрэтацыі камбінацыі параметраў"

#: adduser:882
#, perl-format
msgid "Adding new group `%s' (%d) ..."
msgstr "Дадаецца новая група «%s» (%d)..."

#: adduser:885
#, perl-format
msgid "Adding new group `%s' (new group ID) ..."
msgstr "Дадаецца новая група «%s» (ідэнтыфікатар новай групы)..."

#: adduser:888
#, perl-format
msgid "new group '%s' created with GID %d"
msgstr "новая група «%s» створана з GID %d"

#: adduser:907
#, perl-format
msgid "Adding new user `%s' (%d) with group `%s (%d)' ..."
msgstr "Дадаецца новы карыстальнік «%s» (%d) з групай «%s (%d)»..."

#: adduser:944
msgid "Permission denied"
msgstr "У дазволе адмоўлена"

#: adduser:946
msgid "invalid combination of options"
msgstr "памылковая камбінацыя параметраў"

#: adduser:948
msgid "unexpected failure, nothing done"
msgstr "нечаканы збой, нічога не зроблена"

#: adduser:950
msgid "unexpected failure, passwd file missing"
msgstr "нечаканы збой, файл passwd адсутнічае"

#: adduser:952
msgid "passwd file busy, try again"
msgstr "файл passwd заняты, паспрабуйце яшчэ раз"

#: adduser:954
msgid "invalid argument to option"
msgstr "памылковы аргумент у параметры"

#: adduser:965
msgid "Try again? [y/N] "
msgstr "Паспрабаваць яшчэ раз? [т/Н] "

#: adduser:991
msgid "Is the information correct? [Y/n] "
msgstr "Дадзеная інфармацыя з'яўляецца слушнай? [Y/n] "

#: adduser:1005
#, perl-format
msgid "Adding new user `%s' to supplemental / extra groups `%s' ..."
msgstr "Дадаецца новы карыстальнік «%s» у дапаможныя або дадатковыя групы «%s»..."

#: adduser:1029
#, perl-format
msgid "Setting quota for user `%s' to values of user `%s' ..."
msgstr "Налада квоты для карыстальніка «%s» у значэннях карыстальніка «%s»..."

#: adduser:1067
#, perl-format
msgid "Not creating `%s'."
msgstr "Не ствараецца «%s»."

#: ../adduser:917
#, perl-format
msgid "Not creating home directory `%s'."
msgstr "Хатні каталог «%s» не ствараецца."

#: adduser:1072
#, perl-format
msgid "The home directory `%s' already exists.  Not touching this directory."
msgstr "Хатні каталог «%s» ужо існуе. Гэты каталог не будзе зменены."

#: adduser:1078
#, perl-format
msgid "Warning: The home directory `%s' does not belong to the user you are currently creating."
msgstr "Папярэджанне: хатні каталог «%s» не належыць карыстальніку, якога вы ў дадзены момант ствараеце."

#: adduser:1082
#, perl-format
msgid "Creating home directory `%s' ..."
msgstr "Стварэнне хатняга каталога «%s»..."

#: adduser:1085
#, perl-format
msgid "Couldn't create home directory `%s': %s."
msgstr "Не ўдалося стварыць хатні каталог «%s»: %s."

#: adduser:1099
#, perl-format
msgid "Copying files from `%s' ..."
msgstr "Капіяванне файла з «%s»..."

#: adduser:1102
#, perl-format
msgid "fork for `find' failed: %s"
msgstr "збой fork для «find»: %s"

#: adduser:1214
#, perl-format
msgid "The user `%s' already exists, and is not a system user."
msgstr "Карыстальнік «%s» ужо існуе і ён не з'яўляецца сістэмным карыстальнікам."

#: adduser:1223
#, perl-format
msgid "The user `%s' already exists."
msgstr "Карыстальнік «%s» ужо існуе."

#: ../adduser:1073
#, perl-format
msgid "The UID %d is already in use."
msgstr "UID %d ужо выкарыстоўваецца."

#: adduser:1236
#, perl-format
msgid "The GID %d is already in use."
msgstr "GID %d ужо выкарыстоўваецца."

#: ../adduser:1095
#, perl-format
msgid "The GID %d does not exist."
msgstr "GID %d не існуе."

#: adduser:1315
#, perl-format
msgid "%s/%s is neither a dir, file, nor a symlink."
msgstr "%s/%s не з'яўляецца ні каталогам, ні файлам, ні сімвалічнай спасылкай."

#. this check cannot be turned off
#: ../adduser:1196
msgid "To avoid ambiguity with numerical UIDs, usernames which\n"
"            consist of only digits are not allowed."
msgstr "Імёны карыстальнікаў, якія складаюцца толькі з лічбаў, не дапускаюцца.\n"
"            Гэта забарона дазваляе пазбегнуць не адназначнасці з лічбавымі UID."

#. this check cannot be turned off
#: ../adduser:1203
msgid "Usernames must be no more than 32 bytes in length;\n"
"            note that if you are using Unicode characters, the character\n"
"            limit will be less than 32."
msgstr "Імёны карыстальнікаў не павінны перавышаць 32 байты;\n"
"            звярніце ўвагу, што калі вы выкарыстоўваеце сімвалы Unicode, \n"
"            то абмежаванне будзе менш за 32 сімвалы."

#: adduser:1367
msgid "To avoid problems, the username must not start with a\n"
"            dash, plus sign, or tilde, and it must not contain any of the\n"
"            following: colon, comma, slash, or any whitespace characters\n"
"            including spaces, tabs, and newlines."
msgstr "Імя карыстальніка не павінна пачынацца са \n"
"            злучка, знака «плюс» або тыльды, а таксама не павінна змяшчаць \n"
"            наступныя сімвалы: двукроп'е, коску, косую рысу прабел або любыя \n"
"            прабелы, у тым ліку прабелы, якія ўключаюць табуляцыю і сімвалы новага радка.\n"
"            Гэта дазволіць пазбегнуць праблем."

#: adduser:1382
msgid "To avoid problems, the username should consist only of\n"
"            letters, digits, underscores, periods, at signs and dashes, and\n"
"            not start with a dash (as defined by IEEE Std 1003.1-2001). For\n"
"            compatibility with Samba machine accounts, $ is also supported\n"
"            at the end of the username.  (Use the `--allow-all-names' option\n"
"            to bypass this restriction.)"
msgstr "Імя карыстальніка павінна складацца толькі з \n"
"            літар, лічбаў, падкрэсліванняў, прамежкаў, знакаў @ і злучкоў,\n"
"            а таксама не пачынацца са злучка (у адпаведнасці са стандартам IEEE Std 1003.1-2001). Для\n"
"            сумяшчальнасці з машыннымі ўліковымі запісамі Samba у канцы імя карыстальніка таксама\n"
"            дапускаецца знак $ (выкарыстоўвайце параметр --allow-all-names, каб абысці гэтае абмежаванне).\n"
"            Гэта дазволіць пазбегнуць праблем."

#: adduser:1395
msgid "Allowing use of questionable username."
msgstr "Дазваляць выкарыстоўваць сумнеўнае імя карыстальніка."

#: adduser:1394
#, perl-format
msgid "Please enter a username matching the regular expression\n"
"            configured via the %s configuration variable.  Use the\n"
"            `--allow-bad-names' option to relax this check or reconfigure\n"
"            %s in configuration."
msgstr "Увядзіце імя карыстальніка, якое адпавядае рэгулярнаму выразу \n"
"            сканфігурыраванаму праз пераменную канфігурацыі %s. Выкарыстоўвайце \n"
"            параметр «--allow-bad-names», каб паслабіць гэту праверку або пераканфігурыраваць\n"
"            %s у канфігурацыі."

#: adduser:1426
#, perl-format
msgid "Selecting UID from range %d to %d ...\n"
msgstr "Выбар UID з дыяпазону ад %d да %d...\n"

#: adduser:1449
#, perl-format
msgid "Selecting GID from range %d to %d ..."
msgstr "Выбар GID з дыяпазону ад %d да %d..."

#: adduser:1473
#, perl-format
msgid "Selecting UID/GID from range %d to %d ..."
msgstr "Выбар UID/GID з дыяпазону ад %d да %d..."

#: adduser:1509
#, perl-format
msgid "Removing directory `%s' ..."
msgstr "Выдаленне каталога «%s»..."

#: adduser:1513 deluser:441
#, perl-format
msgid "Removing user `%s' ..."
msgstr "Выдаленне карыстальніка «%s»..."

#: adduser:1517 deluser:483
#, perl-format
msgid "Removing group `%s' ..."
msgstr "Выдаленне групы «%s»..."

#: adduser:1527
#, perl-format
msgid "Caught a SIG%s."
msgstr "Атрыманы сігнал SIG%s."

#: adduser:1533
#, perl-format
msgid "adduser version %s\n\n"
msgstr ""

#: adduser:1534
msgid "Adds a user or group to the system.\n\n"
"For detailed copyright information, please refer to\n"
"/usr/share/doc/adduser/copyright.\n\n"
msgstr "Дадаванне карыстальніка або групы ў сістэму.\n\n"
"Падрабязную інфармацыю аб аўтарскіх правах можна знайсці па спасылцы /usr/share/doc/adduser/copyright\n\n"

#: adduser:1540 deluser:543
msgid "This program is free software; you can redistribute it and/or modify\n"
"it under the terms of the GNU General Public License as published by\n"
"the Free Software Foundation; either version 2 of the License, or (at\n"
"your option) any later version.\n\n"
"This program is distributed in the hope that it will be useful, but\n"
"WITHOUT ANY WARRANTY; without even the implied warranty of\n"
"MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU\n"
"General Public License, /usr/share/common-licenses/GPL, for more details.\n"
msgstr "Гэта праграма распаўсюджваецца свабодна; вы можаце распаўсюджваць і/або змяняць яе згодна з умовамі ліцэнзіі GNU General Public License, якая апублікавана Free Software Foundation; версіі ліцэнзіі 2.0 або (на ваш выбар) больш позняй.\n\n"
"Гэта праграма распаўсюджваецца з надзеяй, што яна будзе карысная, але\n"
"БЕЗ НІЯКІХ ГАРАНТЫЙ; яна нават не прадугледжвае гарантыю ГАНДЛЁВАЙ ПРЫДАТНАСЦІ або таго, што яна будзе пасаваць для нейкага АДМЫСЛОВАГА ПРЫЗНАЧЭННЯ. За больш падрабязнай інфармацыяй, звярніцеся да \n"
"GNU General Public License, які размяшчаецца ў /usr/share/common-licenses/GPL.\n"

#: ../adduser:1387
msgid "adduser [--uid id] [--firstuid id] [--lastuid id]\n"
"        [--gid id] [--firstgid id] [--lastgid id] [--ingroup group]\n"
"        [--add-extra-groups] [--shell shell]\n"
"        [--comment comment] [--home dir] [--no-create-home]\n"
"        [--allow-all-names] [--allow-bad-names]\n"
"        [--disabled-password] [--disabled-login]\n"
"        [--conf file] [--quiet] [--verbose] [--debug]\n"
"        user\n"
"    Add a normal user\n\n"
"adduser --system\n"
"        [--uid id] [--group] [--ingroup group] [--gid id]\n"
"        [--shell shell] [--comment comment] [--home dir] [--no-create-home]\n"
"        [--conf file] [--quiet] [--verbose] [--debug]\n"
"        user\n"
"   Add a system user\n\n"
"adduser --group\n"
"        [--gid ID] [--firstgid id] [--lastgid id]\n"
"        [--conf file] [--quiet] [--verbose] [--debug]\n"
"        group\n"
"addgroup\n"
"        [--gid ID] [--firstgid id] [--lastgid id]\n"
"        [--conf file] [--quiet] [--verbose] [--debug]\n"
"        group\n"
"   Add a user group\n\n"
"addgroup --system\n"
"        [--gid id]\n"
"        [--conf file] [--quiet] [--verbose] [--debug]\n"
"        group\n"
"   Add a system group\n\n"
"adduser USER GROUP\n"
"   Add an existing user to an existing group\n"
msgstr "adduser [--uid ідэнтыфікатар] [--firstuid ідэнтыфікатар] [--lastuid ідэнтыфікатар]\n"
"        [--gid ідэнтыфікатар] [--firstgid ідэнтыфікатар] [--lastgid ідэнтыфікатар] [--ingroup група]\n"
"        [--add-extra-groups] [--shell абалонка]\n"
"        [--comment каментарый] [--home каталог] [--no-create-home]\n"
"        [--allow-all-names] [--allow-bad-names]\n"
"        [--disabled-password] [--disabled-login]\n"
"        [--conf файл] [--quiet] [--verbose] [--debug]\n"
"        карыстальнік\n"
"    Дадаць звычайнага карыстальніка\n\n"
"adduser --system\n"
"        [--uid ідэнтыфікатар] [--group] [--ingroup група] [--gid ідэнтыфікатар]\n"
"        [--shell абалонка] [--comment каментарый] [--home каталог] [--no-create-home]\n"
"        [--conf файл] [--quiet] [--verbose] [--debug]\n"
"        карыстальнік \n"
"   Дадаць сістэмнага карыстальніка\n\n"
"adduser --group\n"
"        [--gid ідэнтыфікатар] [--firstgid ідэнтыфікатар] [--lastgid ідэнтыфікатар]\n"
"        [--conf файл] [--quiet] [--verbose] [--debug]\n"
"        група\n"
"addgroup\n"
"        [--gid ідэнтыфікатар] [--firstgid ідэнтыфікатар] [--lastgid ідэнтыфікатар]\n"
"        [--conf файл] [--quiet] [--verbose] [--debug]\n"
"        група\n"
"   Дадаць групу карыстальнікаў\n\n"
"addgroup --system\n"
"        [--gid ідэнтыфікатар]\n"
"        [--conf файл] [--quiet] [--verbose] [--debug]\n"
"        група\n"
"   Дадаць сістэмную групу\n\n"
"adduser ГРУПА КАРЫСТАЛЬНІКАЎ\n"
"   Дадаць існуючага карыстальніка ў існуючую групу\n"

#: deluser:170
msgid "Only root may remove a user or group from the system."
msgstr "Толькі суперкарыстальнік можа выдаліць карыстальніка або групу з сістэмы."

#: adduser:266 deluser:200
msgid "No options allowed after names."
msgstr "Забаронена ўказваць параметры пасля імён."

#: ../deluser:167
msgid "Enter a group name to remove: "
msgstr "Увядзіце назву групы для выдалення: "

#: ../deluser:169
msgid "Enter a user name to remove: "
msgstr "Увядзіце імя карыстальніка для выдалення: "

#: deluser:271 deluser:290
msgid "In order to use the --remove-home, --remove-all-files, and --backup features, you need to install the `perl' package. To accomplish that, run apt-get install perl."
msgstr "Усталюйце пакет «perl», каб выкарыстоўваць функцыі --remove-home, --remove-all-files і --backup. Для гэтага запусціце каманду apt-get install perl."

#: deluser:281
#, perl-format
msgid "The user `%s' is not a system user. Exiting."
msgstr "Карыстальнік «%s» не з'яўляецца сістэмным карыстальнікам. Адбываецца выхад."

#: deluser:285
#, perl-format
msgid "The user `%s' does not exist, but --system was given. Exiting."
msgstr "Карыстальнік «%s» не існуе, але быў зададзены параметр --system. Адбываецца выхад."

#: deluser:294
msgid "WARNING: You are just about to delete the root account (uid 0). Usually this is never required as it may render the whole system unusable. If you really want this, call deluser with parameter --no-preserve-root. Stopping now without having performed any action"
msgstr "ПАПЯРЭДЖАННЕ: вы збіраецеся выдаліць уліковы запіс суперкарыстальніка (uid 0). Звычайна гэта не патрабуецца, бо можа зрабіць усю сістэму непрыдатнай для выкарыстання. Выклікайце deluser з параметрам --no-preserve-root, калі вы сапраўды хочаце зрабіць гэта дзеянне. Спыніцца цяпер і не выконваць ніякіх дзеянняў"

