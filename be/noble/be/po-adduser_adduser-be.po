"         [--verbose] [--debug] group\n"
"  remove a group from the system\n\n"
"deluser [--conf file] [--quiet] [--verbose] [--debug] user group\n"
"  remove the user from a group\n"
msgstr "deluser [--system] [--remove-home] [--remove-all-files] [--backup]\n"
"        [--backup-to-dir] [--backup-suffix радок] [--conf файл]\n"
"        [--quiet] [--verbose] [--debug] карыстальнік\n\n"
"  выдаліць звычайнага карыстальніка з сістэмы\n\n"
"deluser --group [--system] [--only-if-empty] [--conf файл] [--quiet]\n"
"        [--verbose] [--debug] група\n"
"delgroup [--system] [--only-if-empty] [--conf файл] [--quiet]\n"
"         [--verbose] [--debug] група\n"
"  выдаліць групу з сістэмы\n\n"
"deluser [--conf файл] [--quiet] [--verbose] [--debug] група карыстальнікаў\n"
"  выдаліць карыстальніка з групы\n"

